{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AgentShield default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "autostart:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "open": "^(https://.+|x-apple\\.systempreferences:.+|ms-settings:.+)$"
        }
      ]
    },
    "notification:default"
  ]
}
