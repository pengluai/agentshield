# Copy this file to .env.public-sale.local and fill real values.
# This file is for local readiness checks only. Do not commit secrets.

# Checkout URLs used by the desktop app Upgrade page.
VITE_CHECKOUT_MONTHLY_URL=https://checkout.example.com/monthly
VITE_CHECKOUT_YEARLY_URL=https://checkout.example.com/yearly
VITE_CHECKOUT_LIFETIME_URL=https://checkout.example.com/lifetime

# App-side online license verification endpoint (public URL, no admin auth).
AGENTSHIELD_LICENSE_GATEWAY_URL=https://license.example.com
AGENTSHIELD_LICENSE_PUBLIC_KEY=replace_with_base64url_public_key

# License Gateway secrets.
LEMONSQUEEZY_WEBHOOK_SECRET=replace_with_webhook_secret
LICENSE_GATEWAY_ADMIN_PASSWORD=replace_with_admin_password
AGENTSHIELD_LICENSE_SIGNING_SEED=replace_with_base64url_seed

# Email delivery (recommended for production).
RESEND_API_KEY=re_xxx
LICENSE_DELIVERY_FROM_EMAIL="AgentShield <license@updates.example.com>"
LICENSE_DELIVERY_REPLY_TO=support@example.com

# Optional override for local gateway persistence.
LICENSE_GATEWAY_DATA_PATH=/absolute/path/to/license-gateway.json

# Required for full public signed release checks.
APPLE_ID=developer-account@example.com
APPLE_PASSWORD=app-specific-password
APPLE_TEAM_ID=TEAMID1234
APPLE_SIGNING_IDENTITY="Developer ID Application: Example Corp (TEAMID1234)"

TAURI_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=replace_with_private_key_password
TAURI_UPDATER_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"
TAURI_UPDATER_ENDPOINT=https://github.com/<owner>/<repo>/releases/latest/download/latest.json

WINDOWS_CERTIFICATE_THUMBPRINT=REPLACE_WITH_WINDOWS_CERT_THUMBPRINT
WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com

# Optional in local checks, required on CI if cert import is automated.
WINDOWS_CERTIFICATE=base64_pfx_content
WINDOWS_CERTIFICATE_PASSWORD=replace_with_pfx_password
