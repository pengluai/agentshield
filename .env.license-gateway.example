LICENSE_GATEWAY_PORT=8787
LICENSE_GATEWAY_DATA_PATH=data/license-gateway.json

# Lemon Squeezy webhook signing secret
# Recommended webhook events:
# - order_created
# - order_refunded
# - subscription_payment_refunded
LEMONSQUEEZY_WEBHOOK_SECRET=

# Admin API basic auth
LICENSE_GATEWAY_ADMIN_USERNAME=admin
LICENSE_GATEWAY_ADMIN_PASSWORD=

# 32-byte hex or base64url seed, same format used by issue_activation_code
AGENTSHIELD_LICENSE_SIGNING_SEED=

# Optional: prebuilt issuer binary path. If omitted, gateway will call:
# cargo run --manifest-path src-tauri/Cargo.toml --bin issue_activation_code -- issue ...
# AGENTSHIELD_LICENSE_ISSUER_BIN=/absolute/path/to/issue_activation_code

# Optional: real email delivery via Resend
# RESEND_API_KEY=
# LICENSE_DELIVERY_FROM_EMAIL=AgentShield <noreply@example.com>
# LICENSE_DELIVERY_REPLY_TO=support@example.com
